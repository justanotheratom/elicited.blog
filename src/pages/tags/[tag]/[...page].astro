---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const { page, tagName } = Astro.props;
const isPaginatedPage = page.currentPage > 1;
const pageTitle = isPaginatedPage
  ? `Tag: ${tagName} | Page ${page.currentPage} | ${SITE.title}`
  : `Tag: ${tagName} | ${SITE.title}`;
const pageDescription = isPaginatedPage
  ? `Page ${page.currentPage} of articles tagged "${tagName}" on ${SITE.title}.`
  : `Browse articles tagged "${tagName}" on ${SITE.title}.`;
---

<Layout
  title={pageTitle}
  description={pageDescription}
  robots={isPaginatedPage ? "noindex,follow" : undefined}
>
  <Header />
  <Main
    pageTitle={`Tag: ${tagName}`}
    pageDesc={`All the articles with the tag "${tagName}".`}
  >
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
